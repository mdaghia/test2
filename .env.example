NODE_ENV=development
PORT=5000

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGO_URI=mongodb://admin:secret@localhost:27017/tax_db?authSource=admin

# Redis
REDIS_PASSWORD=redissecret
REDIS_URL=redis://:redissecret@localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=change_me_in_production_use_256bit_random_string
JWT_EXPIRES_IN=8h

# Stampe / PDF
PDF_OUTPUT_DIR=./output
PDF_TEMPLATE_DIR=./templates

# Oracle ACSOR (database del comune)
ORACLE_HOST=acsor.comune.it
ORACLE_PORT=1521
ORACLE_SERVICE=ACSOR
ORACLE_USER=tributi_ro
ORACLE_PASSWORD=oracle_password
ORACLE_SCHEMA=ACSOR

# Sync Service
SYNC_API_KEY=sync-secret-key-change-in-prod
SYNC_BATCH_SIZE=200

# n8n Orchestratore
N8N_USER=admin
N8N_PASSWORD=n8nsecret
N8N_WEBHOOK_URL=http://localhost:5678

# AI / RAG
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QDRANT_URL=http://localhost:6333

# Comune
COMUNE_NOME=Comune di Esempio
COMUNE_CODICE_BELFIORE=H501
COMUNE_CODICE_FISCALE=01234567890
ANNO_IMPOSTA_DEFAULT=2024
